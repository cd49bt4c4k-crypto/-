{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.11"
      }
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "static/$1"
    },
    {
      "src": "/",
      "dest": "static/index.html"
    }
  ],
  "env": {
    "NETEASE_API_URL": "https://autumnfish.cn"
  }
}
